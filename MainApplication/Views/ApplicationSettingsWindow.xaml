<Window x:Class="MainApplication.Views.ApplicationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Icon="/Assets/AppIcon.ico"
        Width="420"
        Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="12"
          Background="{DynamicResource WindowBackgroundBrush}"
          TextElement.Foreground="{DynamicResource WindowTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="自動バックアップ"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TaskEditorHeadingTextBrush}"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="96"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="保持世代数"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                     Text="{Binding AutoBackupGenerationCount, UpdateSourceTrigger=PropertyChanged}"
                     HorizontalContentAlignment="Right"
                     VerticalContentAlignment="Center"
                     Height="24"
                     MaxLength="3"/>
            <TextBlock Grid.Column="2"
                       Text="世代"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"/>
            <TextBlock Grid.Column="3"
                       Text="0の場合はバックアップを作成しません。"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="適用して閉じる"
                    Command="{Binding SaveCommand}"
                    Width="112"
                    Margin="0,0,8,0"/>
            <Button Content="キャンセル"
                    Width="72"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
