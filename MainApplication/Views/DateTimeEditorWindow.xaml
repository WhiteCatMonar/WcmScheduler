<Window x:Class="MainApplication.Views.DateTimeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日時編集"
        WindowStartupLocation="CenterOwner"
        Width="250" Height="330"
        ResizeMode="NoResize">

    <StackPanel Margin="10">
        <!-- カレンダー -->
        <Calendar SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Margin="0,0,0,8"/>

        <!-- 時刻入力(スピンボタン付き) -->
        <DockPanel LastChildFill="False">
            <TextBlock Text="時刻" Width="48" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding Hour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="40" PreviewTextInput="DigitsOnly"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                         MaxLength="2" Margin="0,0,0,0"/>
                <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                    <RepeatButton Command="{Binding IncreaseHourCommand}" FontSize="8" Width="18" Height="10">
                        <RepeatButton.Content>
                            <TextBlock Text="▲" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </RepeatButton.Content>
                    </RepeatButton>
                    <RepeatButton Command="{Binding DecreaseHourCommand}" FontSize="8" Width="18" Height="10">
                        <RepeatButton.Content>
                            <TextBlock Text="▼" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </RepeatButton.Content>
                    </RepeatButton>
                </StackPanel>

                <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <TextBox Text="{Binding Minute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="40" PreviewTextInput="DigitsOnly"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                         MaxLength="2" Margin="0,0,0,0"/>
                <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                    <RepeatButton Command="{Binding IncreaseMinuteCommand}" FontSize="8" Width="18" Height="10">
                        <RepeatButton.Content>
                            <TextBlock Text="▲" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </RepeatButton.Content>
                    </RepeatButton>
                    <RepeatButton Command="{Binding DecreaseMinuteCommand}" FontSize="8" Width="18" Height="10">
                        <RepeatButton.Content>
                            <TextBlock Text="▼" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </RepeatButton.Content>
                    </RepeatButton>
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <!-- プレビュー -->
        <TextBlock Margin="0,10,0,0" Text="{Binding Composed, StringFormat='選択中: yyyy/MM/dd HH:mm'}"/>

        <!-- OK / Cancel -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Margin="6,0,0,0" IsDefault="True"
                    Command="{Binding ConfirmCommand}" Click="Ok_Click"/>
            <Button Content="キャンセル" Margin="6,0,0,0" IsCancel="True"/>
            <Button Content="クリア" Margin="6,0,0,0"
                    Command="{Binding ClearCommand}" Click="Clear_Click"/>

        </StackPanel>
    </StackPanel>
</Window>

