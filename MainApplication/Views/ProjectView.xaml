<UserControl x:Class="MainApplication.Views.ProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sidebar="clr-namespace:MainApplication.Views.ProjectEditor.Sidebar"
             xmlns:dependencyEditor="clr-namespace:MainApplication.Views.ProjectEditor.DependencyEditor"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="VerticalGridSplitter" TargetType="{x:Type GridSplitter}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="5"/>
        </Style>

        <DataTemplate x:Key="PlaceholderTemplate">
            <TextBlock Text="タスクが選択されていません"
                       Foreground="{DynamicResource PlaceholderTextBrush}"
                       FontStyle="Italic"
                       Margin="5"/>
        </DataTemplate>

        <DataTemplate x:Key="TaskDetailTemplate">
            <sidebar:TaskDetailControl DataContext="{Binding}"/>
        </DataTemplate>

        <sidebar:TaskDetailTemplateSelector
            x:Key="TaskDetailTemplateSelector"
            PlaceholderTemplate="{StaticResource PlaceholderTemplate}"
            TaskDetailTemplate="{StaticResource TaskDetailTemplate}"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}"
          TextElement.Foreground="{DynamicResource WindowTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="プロジェクト名"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="240"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Background="{DynamicResource SidePanelBackgroundBrush}"
                  TextElement.Foreground="{DynamicResource WindowTextBrush}"
                  Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="5">
                    <TextBlock Text="タスク操作"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TaskEditorHeadingTextBrush}"
                               Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="タスク追加"
                                Command="{Binding DependencyEditor.Nodes.AddNodeCommand}"
                                Margin="0,0,2,0"/>
                        <Button Grid.Column="1"
                                Content="選択タスク削除"
                                Command="{Binding DependencyEditor.Nodes.DeleteSelectedNodeCommand}"
                                Focusable="False"
                                Margin="2,0,0,0"/>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="1" Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="タスク情報"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TaskEditorHeadingTextBrush}"
                               Margin="0,0,0,5"/>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="{DynamicResource SidePanelBackgroundBrush}">
                        <ContentControl Content="{Binding DependencyEditor.Nodes.SelectedNode}"
                                        ContentTemplateSelector="{StaticResource TaskDetailTemplateSelector}"/>
                    </ScrollViewer>
                </Grid>

                <sidebar:HistoryControl Grid.Row="2"
                                         DataContext="{Binding DependencyEditor}"/>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Background="{DynamicResource SplitterBackgroundBrush}"
                          Style="{StaticResource VerticalGridSplitter}"/>

            <TabControl Grid.Column="2"
                        Margin="5"
                        Style="{StaticResource ThemedTabControlStyle}"
                        ItemContainerStyle="{StaticResource ThemedTabItemStyle}"
                        SelectionChanged="EditorTabControl_SelectionChanged">
                <TabItem Header="依存関係編集">
                    <dependencyEditor:DependencyEditorView DataContext="{Binding DependencyEditor}"/>
                </TabItem>
                <TabItem Header="プロジェクトスケジュール">
                    <ContentControl Content="{Binding GanttChart}"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
