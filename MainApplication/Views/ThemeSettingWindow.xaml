<Window x:Class="MainApplication.Views.ThemeSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="テーマ編集"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- テーマ名 -->
            <RowDefinition Height="*"/>
            <!-- 色一覧 -->
            <RowDefinition Height="Auto"/>
            <!-- ボタン -->
        </Grid.RowDefinitions>

        <!-- テーマ名 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="テーマ名：" VerticalAlignment="Center"/>
            <TextBox Text="{Binding ThemeName}" Width="200" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- 色一覧 -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding EditableColors}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="項目" Binding="{Binding Key}" Width="2*"/>
                <DataGridTemplateColumn Header="色" Width="3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="20" Height="20"
                                        Margin="0,0,6,0"
                                        BorderBrush="#808080"
                                        BorderThickness="1"
                                        Background="{Binding PreviewBrush}"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="9"
                                         CharacterCasing="Upper"
                                         VerticalContentAlignment="Center"/>

                                <Button Grid.Column="2"
                                        Content="選択"
                                        Margin="6,0,0,0"
                                        Command="{Binding DataContext.EditColorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ボタン -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">

            <Button Content="保存"
                    Command="{Binding SaveCommand}"
                    Margin="0,0,10,0"/>

            <Button Content="閉じる"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
