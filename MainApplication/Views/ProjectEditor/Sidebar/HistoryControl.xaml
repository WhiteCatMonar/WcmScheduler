<UserControl x:Class="MainApplication.Views.ProjectEditor.Sidebar.HistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:MainApplication.Views.Behaviors">
    <Expander Header="履歴操作"
              IsExpanded="False"
              Margin="5"
              Background="{DynamicResource HistoryPanelBackgroundBrush}"
              Foreground="{DynamicResource TaskEditorHeadingTextBrush}">
        <StackPanel Margin="0,5,0,0"
                    TextElement.Foreground="{DynamicResource WindowTextBrush}">

        <!-- Undo/Redo ボタン -->
        <Button Content="戻す" Command="{Binding UndoCommand}" Margin="0,0,0,5"/>
        <Button Content="進む" Command="{Binding RedoCommand}" Margin="0,0,0,10"/>

        <!-- 履歴リスト -->
        <ListBox ItemsSource="{Binding UndoRedo.History}"
                 behaviors:ListBoxAutoScrollBehavior.AutoScroll="True"
                 Background="{DynamicResource HistoryListBackgroundBrush}"
                 Foreground="{DynamicResource HistoryTextBrush}"
                 Height="200"
                 SelectionMode="Single">
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        
                        <!-- アイコン部分(テキストアイコンに戻す) -->
                        <TextBlock FontSize="14" Width="20" TextAlignment="Center" Margin="0,0,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="📝"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActionType}" Value="AddNode">
                                            <Setter Property="Text" Value="➕"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActionType}" Value="DeleteNode">
                                            <Setter Property="Text" Value="🗑️"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActionType}" Value="MoveNode">
                                            <Setter Property="Text" Value="↔"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActionType}" Value="AddConnection">
                                            <Setter Property="Text" Value="🔗"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActionType}" Value="DeleteConnection">
                                            <Setter Property="Text" Value="❌"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- タイムスタンプ部分 -->
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy/MM/dd HH:mm:ss}'}"
                                   Foreground="{DynamicResource HistoryTimestampTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <!-- 説明部分 -->
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{DynamicResource HistoryTextBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource HistoryCurrentTextBrush}"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <!-- ハイライト用スタイル -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="behaviors:ListBoxItemDoubleClickBehavior.Command"
                            Value="{Binding DataContext.MoveToHistoryCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                    <Setter Property="behaviors:ListBoxItemDoubleClickBehavior.CommandParameter" Value="{Binding}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{DynamicResource HistoryCurrentTextBrush}"/>
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource HistorySelectedBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource Self}}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            
        </ListBox>
        </StackPanel>
    </Expander>
</UserControl>
