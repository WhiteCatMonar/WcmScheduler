<UserControl x:Class="MainApplication.Views.ProjectEditor.DependencyEditor.ConnectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views_ne_tab="clr-namespace:MainApplication.Views.ProjectEditor.DependencyEditor">
    <Path x:Name="ConnectionPath"
          StrokeThickness="2"
          SnapsToDevicePixels="True"
          StrokeStartLineCap="Round"
          StrokeEndLineCap="Round"
          IsHitTestVisible="True"
          Tag="{Binding DataContext,
                        RelativeSource={RelativeSource AncestorType=views_ne_tab:DependencyEditorView}}">
        <Path.Style>
            <Style TargetType="Path">
                <Setter Property="Stroke" Value="{DynamicResource ConnectionStrokeBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Stroke" Value="{DynamicResource ConnectionSelectedStrokeBrush}"/>
                        <Setter Property="StrokeThickness" Value="3"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Path.Style>

        <Path.Data>
            <PathGeometry>
                <PathFigure StartPoint="{Binding FromPosition}">
                    <BezierSegment Point1="{Binding FromBezierControlPoint}"
                                   Point2="{Binding ToBezierControlPoint}"
                                   Point3="{Binding ToPosition}" />
                </PathFigure>
            </PathGeometry>
        </Path.Data>

        <Path.ContextMenu>
            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                <MenuItem Header="接続線を削除" Command="{Binding Connections.DeleteSelectedConnectionCommand}" />
            </ContextMenu>
        </Path.ContextMenu>

        <i:Interaction.Triggers>
            <i:EventTrigger EventName="MouseLeftButtonDown">
                <i:InvokeCommandAction Command="{Binding Tag.Connections.SelectConnectionCommand,
                                                         ElementName=ConnectionPath}"
                                       CommandParameter="{Binding}" />
            </i:EventTrigger>
            <i:EventTrigger EventName="MouseRightButtonUp">
                <i:InvokeCommandAction Command="{Binding Tag.Connections.SelectConnectionCommand,
                                                         ElementName=ConnectionPath}"
                                       CommandParameter="{Binding}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>
    </Path>
</UserControl>
