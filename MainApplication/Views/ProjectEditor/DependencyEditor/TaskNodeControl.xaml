<UserControl x:Class="MainApplication.Views.ProjectEditor.DependencyEditor.TaskNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MainApplication.ViewModels.Converters"
             xmlns:controls="clr-namespace:MainApplication.Views.ProjectEditor.DependencyEditor"
             xmlns:dependencyModel="clr-namespace:MainApplication.ViewModels.DependencyEditorModel"
             MouseMove="TaskNodeControl_MouseMove"
             MouseLeftButtonUp="TaskNodeControl_MouseLeftButtonUp"
             MouseLeftButtonDown="TaskNodeControl_MouseLeftButtonDown"
             MouseRightButtonUp="TaskNodeControl_MouseRightButtonUp"
             MinWidth="{Binding MinWidth}" MinHeight="{Binding MinHeight}"
             SizeChanged="TaskNodeControl_SizeChanged">

    <Border x:Name="NodeBorder"
        BorderThickness="2" CornerRadius="5"
        MouseLeftButtonDown="NodeBorder_MouseLeftButtonDown">
        <Border.Style>
            <Style TargetType="Border">
                <!-- 通常時の背景 -->
                <Setter Property="Background" Value="{DynamicResource NodeBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusReadyBrush}" />

                <!-- 選択時の背景 -->
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dependencyModel:TaskNodeViewModel+TaskStatus.Pending}">
                        <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusPendingBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dependencyModel:TaskNodeViewModel+TaskStatus.InProgress}">
                        <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusInProgressBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Status}" Value="{x:Static dependencyModel:TaskNodeViewModel+TaskStatus.Done}">
                        <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusDoneBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background"
                                Value="{DynamicResource NodeSelectedBackgroundBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid TextElement.Foreground="{DynamicResource NodeTextBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Margin="-2,0,0,0"
                    CornerRadius="3,0,0,3">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource NodeStatusReadyBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="{x:Static dependencyModel:TaskNodeViewModel+TaskStatus.Pending}">
                                <Setter Property="Background" Value="{DynamicResource NodeStatusPendingBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="{x:Static dependencyModel:TaskNodeViewModel+TaskStatus.InProgress}">
                                <Setter Property="Background" Value="{DynamicResource NodeStatusInProgressBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="{x:Static dependencyModel:TaskNodeViewModel+TaskStatus.Done}">
                                <Setter Property="Background" Value="{DynamicResource NodeStatusDoneBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Grid Grid.Column="1" Margin="4,2,4,2">
            <Grid.RowDefinitions>
                <!-- タスク名 -->
                <RowDefinition Height="Auto"/>
                <!-- 入力ポート -->
                <RowDefinition Height="Auto"/>
                <!-- 出力ポート -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Width="22"
                    Height="22"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{DynamicResource MemberBadgeBackgroundBrush}"
                    BorderBrush="{DynamicResource MemberBadgeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="11"
                    Panel.ZIndex="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Detail.HasAssigneeBadge}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Detail.AssigneeInitials}"
                           Foreground="{DynamicResource MemberBadgeTextBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- タスク名 -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Detail.TaskName}"
                       Margin="0,0,36,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       SizeChanged="TaskName_SizeChanged"/>

            <!-- 入力ポート -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding InputPorts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <controls:PortControl Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" Grid.Column="1" Margin="4,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 出力ポート -->
            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding OutputPorts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Name}" Grid.Column="0" Margin="0,0,4,0"/>
                            <controls:PortControl Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
