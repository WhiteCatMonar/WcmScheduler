<UserControl x:Class="MainApplication.Views.NodeEditorTab.Controls.NodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MainApplication.ViewModels.Converters"
             xmlns:controls="clr-namespace:MainApplication.Views.NodeEditorTab.Controls"
             MouseMove="NodeControl_MouseMove"
             MouseLeftButtonUp="NodeControl_MouseLeftButtonUp"
             MouseLeftButtonDown="NodeControl_MouseLeftButtonDown"
             MinWidth="{Binding MinWidth}" MinHeight="{Binding MinHeight}"
             SizeChanged="NodeControl_SizeChanged">
    <UserControl.Resources>
        <converters:SelectionBrushConverter x:Key="SelectionBrushConverter"/>
    </UserControl.Resources>

    <Border x:Name="NodeBorder"
        Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
        BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="5"
        MouseLeftButtonDown="NodeBorder_MouseLeftButtonDown">
        <StackPanel>
            <!-- タスク名 -->
            <TextBlock Text="{Binding TaskName}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <!-- 入力ポート -->
            <ItemsControl ItemsSource="{Binding InputPorts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <controls:PortControl Margin="2" Grid.Column="0"/>
                            <TextBlock Text="{Binding Name}" Margin="0,0,0,5" Grid.Column="1"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 出力ポート -->
            <ItemsControl ItemsSource="{Binding OutputPorts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Name}" Margin="0,0,0,5" Grid.Column="0"/>
                            <controls:PortControl Margin="2" Grid.Column="1"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
