<UserControl x:Class="MainApplication.Views.NodeEditorTab.NodeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:MainApplication.ViewModels"
             xmlns:views="clr-namespace:MainApplication.Views"
             xmlns:controls="clr-namespace:MainApplication.Views.NodeEditorTab.Controls"
             xmlns:converters="clr-namespace:MainApplication.ViewModels.Converters"
             Focusable="True"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <views:BindingProxy x:Key="NodeEditorViewModelProxy" Data="{Binding}" />
    </UserControl.Resources>

    <!-- Undo / Redo -->
    <UserControl.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
    </UserControl.InputBindings>

    <!-- ウィンドウサイズに追従する領域 -->
    <Border BorderBrush="DarkGray"  BorderThickness="1">
        <Canvas x:Name="NodeEditorArea"
                Background="Transparent"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                SizeChanged="NodeEditorArea_SizeChanged"
                ClipToBounds="True">
            
            <!-- ズーム後サイズを持つキャンバス(位置は固定) -->
            <Canvas x:Name="NodeEditorCanvas"
                    Background="White"
                    Width="{Binding BaseCanvasWidth}"
                    Height="{Binding BaseCanvasHeight}"
                    Focusable="True"
                    PreviewMouseDown="NodeEditorCanvas_PreviewMouseDown"
                    MouseWheel="NodeEditorCanvas_MouseWheel"
                    MouseDown="NodeEditorCanvas_MouseDown"
                    MouseMove="NodeEditorCanvas_MouseMove"
                    MouseUp="NodeEditorCanvas_MouseUp">

                <!-- ズーム・パンは ContentRoot にのみ適用 -->
                <Canvas x:Name="ContentRoot"
                        Background="{x:Null}">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="PanTransform" X="0" Y="0"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- グリッド線 -->
                    <ItemsControl ItemsSource="{Binding GridLines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsHitTestVisible="False" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}"
                                      Y1="{Binding Y1}"
                                      X2="{Binding X2}"
                                      Y2="{Binding Y2}">
                                    <Line.Style>
                                        <Style TargetType="Line">
                                            <Setter Property="Stroke" Value="#EEE"/>
                                            <Setter Property="StrokeThickness" Value="0.5"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMajor}" Value="True">
                                                    <Setter Property="StrokeThickness" Value="1.5"/>
                                                    <Setter Property="Stroke" Value="#CCC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Line.Style>
                                </Line>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 原点軸(X軸) -->
                    <Line x:Name="OriginAxisX"
                          X1="{Binding ZoomedCanvasAreaStartX}" Y1="0"
                          X2="{Binding ZoomedCanvasAreaEndX}"
                          Y2="0"
                          Stroke="Red"
                          StrokeThickness="2"
                          SnapsToDevicePixels="True" />

                    <!-- 原点軸(Y軸) -->
                    <Line x:Name="OriginAxisY"
                          X1="0" Y1="{Binding ZoomedCanvasAreaStartY}"
                          X2="0"
                          Y2="{Binding ZoomedCanvasAreaEndY}"
                          Stroke="Blue"
                          StrokeThickness="2"
                          SnapsToDevicePixels="True" />

                    <!-- 接続線 -->
                    <ItemsControl ItemsSource="{Binding Connections.Connections}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                                <Path StrokeThickness="2"
                                      SnapsToDevicePixels="True"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      IsHitTestVisible="True">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Stroke" Value="Red"/>
                                                    <Setter Property="StrokeThickness" Value="3"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>

                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="{Binding FromPosition}">
                                                <BezierSegment Point1="{Binding FromBezierControlPoint}"
                                                       Point2="{Binding ToBezierControlPoint}"
                                                       Point3="{Binding ToPosition}" />
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>

                                    <Path.ContextMenu>
                                        <ContextMenu DataContext="{Binding Source={StaticResource NodeEditorViewModelProxy}, Path=Data}">
                                            <MenuItem Header="接続線を削除" Command="{Binding Connections.DeleteSelectedConnectionCommand}" />
                                        </ContextMenu>
                                    </Path.ContextMenu>

                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.Connections.SelectConnectionCommand,
                                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                        <i:EventTrigger EventName="MouseRightButtonUp">
                                            <i:InvokeCommandAction Command="{Binding DataContext.Connections.SelectConnectionCommand,
                                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Path>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 仮接続線 -->
                    <Path Stroke="Gray" StrokeDashArray="2,2" StrokeThickness="2" IsHitTestVisible="False"
                          Visibility="{Binding Connections.IsDraggingConnection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="{Binding Connections.DraggingFromPoint}">
                                    <BezierSegment Point1="{Binding Connections.DraggingFromPortBezierControlPoint}"
                                       Point2="{Binding Connections.DraggingToPointBezierControl}"
                                       Point3="{Binding Connections.DraggingToPoint}" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- ノード -->
                    <ItemsControl ItemsSource="{Binding Nodes.Nodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                                <controls:NodeControl />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas> <!-- ContentRoot -->
            </Canvas> <!-- NodeEditorCanvas -->
        </Canvas> <!-- NodeEditorArea -->
    </Border>
</UserControl>