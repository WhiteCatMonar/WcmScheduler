<UserControl x:Class="MainApplication.Views.GanttChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gantt="clr-namespace:MainApplication.ViewModels.GanttChartModel"
             xmlns:projectModel="clr-namespace:MainApplication.ViewModels.ProjectModel">
    <UserControl.Resources>
        <Style x:Key="TaskNameTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasWarning}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource NodeStatusPendingBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GanttTaskBarStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Setter Property="Background" Value="{DynamicResource NodeStatusReadyBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusReadyBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSchedule}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static projectModel:NodeViewModel+TaskStatus.Pending}">
                    <Setter Property="Background" Value="{DynamicResource NodeStatusPendingBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusPendingBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static projectModel:NodeViewModel+TaskStatus.InProgress}">
                    <Setter Property="Background" Value="{DynamicResource NodeStatusInProgressBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusInProgressBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static projectModel:NodeViewModel+TaskStatus.Done}">
                    <Setter Property="Background" Value="{DynamicResource NodeStatusDoneBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource NodeStatusDoneBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}"
          TextElement.Foreground="{DynamicResource WindowTextBrush}"
          Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Right"
                    Content="更新"
                    Command="{Binding RefreshCommand}"
                    Width="64"/>
            <TextBlock Text="{Binding TimelineRangeText}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource NodeEditorBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource NodeEditorCanvasBackgroundBrush}">
            <ScrollViewer x:Name="ChartScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          SizeChanged="ChartScrollViewer_SizeChanged">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            BorderBrush="{DynamicResource NodeEditorBorderBrush}"
                            BorderThickness="0,0,1,1"
                            Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="タスク"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="担当者"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="0"
                                  Grid.Column="1"
                                  Width="{Binding ChartWidth}"
                                  Height="42"
                                  ItemsSource="{Binding TimelineDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type gantt:GanttTimelineDayViewModel}">
                                <Border Width="{Binding Width}"
                                        Height="42"
                                        BorderBrush="{DynamicResource NodeEditorBorderBrush}"
                                        BorderThickness="0,0,1,1"
                                        Padding="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DateText}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding DayOfWeekText}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  Grid.Column="0"
                                  ItemsSource="{Binding Tasks}"
                                  Panel.ZIndex="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type gantt:GanttTaskItemViewModel}">
                                <Grid Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>

                                    <Border BorderBrush="{DynamicResource NodeEditorBorderBrush}"
                                            BorderThickness="0,0,1,1"
                                            Padding="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TaskName}"
                                                       Style="{StaticResource TaskNameTextStyle}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTipService.IsEnabled="{Binding HasWarning}">
                                                <ToolTipService.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding TaskName}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding ErrorText}"
                                                                   Foreground="{DynamicResource NodeStatusPendingBrush}"/>
                                                    </StackPanel>
                                                </ToolTipService.ToolTip>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AssigneeName}"
                                                       Opacity="0.8"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Canvas Grid.Row="1"
                            Grid.Column="1"
                            Width="{Binding ChartWidth}"
                            Height="{Binding ChartHeight}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            ClipToBounds="True">
                        <ItemsControl ItemsSource="{Binding Tasks}"
                                      Panel.ZIndex="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding RowTop}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type gantt:GanttTaskItemViewModel}">
                                    <Canvas Width="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Height="48">
                                        <ItemsControl ItemsSource="{Binding DataContext.TimelineDays, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type gantt:GanttTimelineDayViewModel}">
                                                    <Border Width="{Binding Width}"
                                                            Height="48"
                                                            BorderBrush="{DynamicResource NodeEditorBorderBrush}"
                                                            BorderThickness="0,0,1,1"
                                                            Opacity="0.35"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Canvas.Left="{Binding BarLeft}"
                                                Canvas.Top="14"
                                                Width="{Binding BarWidth}"
                                                Height="20"
                                                Style="{StaticResource GanttTaskBarStyle}">
                                            <Grid ClipToBounds="True">
                                                <ItemsControl ItemsSource="{Binding Suspensions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type gantt:GanttSuspensionItemViewModel}">
                                                            <Border Width="{Binding Width}"
                                                                    Height="20"
                                                                    Background="Gray"
                                                                    Opacity="0.65"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                            <ToolTipService.ToolTip>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding TaskName}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding PeriodText}"/>
                                                    <TextBlock Text="{Binding AssigneeName}"/>
                                                </StackPanel>
                                            </ToolTipService.ToolTip>
                                        </Border>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding DependencyLines}"
                                      IsHitTestVisible="False"
                                      Panel.ZIndex="2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type gantt:GanttDependencyLineViewModel}">
                                    <Canvas>
                                        <Path Data="{Binding Geometry}"
                                              Stroke="{DynamicResource WindowTextBrush}"
                                              StrokeThickness="1.5"
                                              Opacity="0.75"/>
                                        <Polygon Points="{Binding ArrowPoints}"
                                                 Fill="{DynamicResource WindowTextBrush}"
                                                 Opacity="0.75"/>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="表示可能なタスクがありません"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.7">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoTasks}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
