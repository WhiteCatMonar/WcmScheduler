<UserControl x:Class="MainApplication.Views.NodeEditorTab.Controls.NodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MainApplication.ViewModels.Converters"
             xmlns:controls="clr-namespace:MainApplication.Views.NodeEditorTab.Controls"
             MouseMove="NodeControl_MouseMove"
             MouseLeftButtonUp="NodeControl_MouseLeftButtonUp"
             MouseLeftButtonDown="NodeControl_MouseLeftButtonDown"
             MinWidth="{Binding MinWidth}" MinHeight="{Binding MinHeight}"
             SizeChanged="NodeControl_SizeChanged">
    <UserControl.Resources>
        <converters:SelectionBrushConverter x:Key="SelectionBrushConverter"/>
    </UserControl.Resources>

    <Border x:Name="NodeBorder"
        Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
        BorderBrush="DarkBlue" BorderThickness="2" CornerRadius="5"
        MouseLeftButtonDown="NodeBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <!-- タスク名 -->
                <RowDefinition Height="Auto"/>
                <!-- 入力ポート -->
                <RowDefinition Height="Auto"/>
                <!-- 出力ポート -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タスク名 -->
            <TextBlock Grid.Row="0"
                       Text="{Binding TaskName}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       SizeChanged="TaskName_SizeChanged"/>

            <!-- 入力ポート -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding InputPorts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <controls:PortControl Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" Grid.Column="1" Margin="4,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 出力ポート -->
            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding OutputPorts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Name}" Grid.Column="0" Margin="0,0,4,0"/>
                            <controls:PortControl Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
