<UserControl x:Class="MainApplication.Views.NodeEditorTab.NodeEditorTab"     
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views="clr-namespace:MainApplication.Views.NodeEditorTab"
             xmlns:controls="clr-namespace:MainApplication.Views.NodeEditorTab.Controls"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             Height="Auto" Width="Auto">
    <UserControl.Resources>
        <Style x:Key="VerticalGridSplitter" TargetType="{x:Type GridSplitter}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="5" />
        </Style>

        <!-- プレースホルダー用テンプレート -->
        <DataTemplate x:Key="PlaceholderTemplate">
            <TextBlock Text="タスクが選択されていません"
                       Foreground="{DynamicResource PlaceholderTextBrush}"
                       FontStyle="Italic"
                       Margin="5"/>
        </DataTemplate>

        <!-- タスク詳細用テンプレート -->
        <DataTemplate x:Key="NodeDetailTemplate">
            <views:NodeDetailControl DataContext="{Binding}" />
        </DataTemplate>

        <!-- TemplateSelector に渡す -->
        <views:NodeDetailTemplateSelector
            x:Key="NodeDetailTemplateSelector"
            PlaceholderTemplate="{StaticResource PlaceholderTemplate}"
            NodeDetailTemplate="{StaticResource NodeDetailTemplate}" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- サイドパネル -->
            <ColumnDefinition Width="320"  MinWidth="320"/>
            <!-- セパレータ -->
            <ColumnDefinition Width="Auto"/>
            <!-- ノードエディタ領域 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

         <!-- サイドパネル -->
        <Grid Grid.Column="0"
              Background="{DynamicResource SidePanelBackgroundBrush}"
              TextElement.Foreground="{DynamicResource WindowTextBrush}"
              Margin="5">
            <Grid.RowDefinitions>
                <!-- 固定UI：タスク操作 -->
                <RowDefinition Height="Auto"/>
                <!-- 動的UI：タスク情報 -->
                <RowDefinition Height="*"/>
                <!-- 固定UI：履歴操作 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 固定UI：タスク操作 -->
            <StackPanel Grid.Row="0" Margin="5">
                <TextBlock Text="タスク操作"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TaskEditorHeadingTextBrush}"
                           Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="タスク追加"
                            Command="{Binding Nodes.AddNodeCommand}"
                            Margin="0,0,2,0"/>
                    <Button Grid.Column="1"
                            Content="選択タスク削除"
                            Command="{Binding Nodes.DeleteSelectedNodeCommand}"
                            Focusable="False"
                            Margin="2,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- 動的UI：タスク情報 -->
            <StackPanel Grid.Row="1" Margin="5">
                <TextBlock Text="タスク情報" FontWeight="Bold" Foreground="{DynamicResource TaskEditorHeadingTextBrush}" Margin="0,0,0,5"/>
                <ContentControl Content="{Binding Nodes.SelectedNode}"
                                ContentTemplateSelector="{StaticResource NodeDetailTemplateSelector}"/>
            </StackPanel>
            
            <!-- 固定UI：履歴操作 -->
            <controls:HistoryControl Grid.Row="2" />

        </Grid>

        <GridSplitter Grid.Column="1" Background="{DynamicResource SplitterBackgroundBrush}" Style="{StaticResource VerticalGridSplitter}" />
        
        <!-- ノードエディタ領域 -->
        <views:NodeEditorControl Grid.Column="2" Margin="5"/>

    </Grid>
</UserControl>
