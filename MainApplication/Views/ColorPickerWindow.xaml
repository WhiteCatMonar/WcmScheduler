<Window x:Class="MainApplication.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="色編集"
        Icon="/Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        Width="360" Height="360"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="変更前" Margin="0,0,0,4"/>
                <Border Height="48" BorderBrush="{DynamicResource ColorPreviewBorderBrush}" BorderThickness="1" Background="{Binding InitialBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="選択中" Margin="0,0,0,4"/>
                <Border Height="48" BorderBrush="{DynamicResource ColorPreviewBorderBrush}" BorderThickness="1" Background="{Binding SelectedBrush}"/>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="1" Margin="0,0,0,12" LastChildFill="True">
            <TextBlock DockPanel.Dock="Left" Text="ARGB" Width="48" VerticalAlignment="Center"/>
            <TextBox Text="{Binding HexText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     CharacterCasing="Upper"
                     MaxLength="9"
                     VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHexValid}" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource StatusBarErrorTextBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="56"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="A" VerticalAlignment="Center"/>
            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" Value="{Binding Alpha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding AlphaText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="DigitsOnly" MaxLength="3" HorizontalContentAlignment="Right"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="R" VerticalAlignment="Center"/>
            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" Value="{Binding Red, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding RedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="DigitsOnly" MaxLength="3" HorizontalContentAlignment="Right"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="G" VerticalAlignment="Center"/>
            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" Value="{Binding Green, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding GreenText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="DigitsOnly" MaxLength="3" HorizontalContentAlignment="Right"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="B" VerticalAlignment="Center"/>
            <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" Value="{Binding Blue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding BlueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="DigitsOnly" MaxLength="3" HorizontalContentAlignment="Right"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Margin="6,0,0,0" IsDefault="True"
                    Command="{Binding ConfirmCommand}"/>
            <Button Content="キャンセル" Margin="6,0,0,0" IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="リセット" Margin="6,0,0,0"
                    Command="{Binding ResetCommand}"/>
        </StackPanel>
    </Grid>
</Window>
