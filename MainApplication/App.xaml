<Application x:Class="MainApplication.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MainApplication.ViewModels"
             xmlns:vm_project="clr-namespace:MainApplication.ViewModels.ProjectModel"
             xmlns:views="clr-namespace:MainApplication.Views"
             xmlns:views_ne_tab="clr-namespace:MainApplication.Views.NodeEditorTab"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        
        <!-- TeamProjectsViewModel → TeamProjectsView -->
        <DataTemplate DataType="{x:Type vm:TeamProjectsViewModel}">
            <views:TeamProjectsView />
        </DataTemplate>
        
        <!-- ProjectViewModel → ProjectView -->
        <DataTemplate DataType="{x:Type vm_project:ProjectViewModel}">
            <views:ProjectView />
        </DataTemplate>

        <!-- NodeEditorViewModel → NodeEditorTab -->
        <DataTemplate DataType="{x:Type vm_project:NodeEditorViewModel}">
            <views_ne_tab:NodeEditorTab />
        </DataTemplate>
        
    </Application.Resources>
</Application>
